VM_NAME=${VM_NAME:-qemu-minimal}
ARCH=${ARCH:-amd64}
VCPUS=${VCPUS:-2}
VMEM=${VMEM:-4096}
FILESYSTEM=${FILESYSTEM:-none}
SSH_PORT=${SSH_PoRT:-2222}

if [ "${ARCH}"=="amd64" ]; then
    QARCH="x86_64"
elif [ "${ARCH}"=="arm64" ]; then
    QARCH="aarch64"
else
    echo "Error: No ARCH mapping exists for ${ARCH}! Exiting."; exit -1
fi

qemu-system-${QARCH} \
   -smp cpus=${VCPUS} \
   -m ${VMEM} \
   -nographic \
   -drive if=virtio,format=qcow2,file=/home/batesste/images/${VM_NAME}.qcow2 \
   -nic user,id=user0,model=virtio-net-pci,hostfwd=tcp::${SSH_PORT}-:22

